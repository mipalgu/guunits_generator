ratorConversions/documentation/GUUnitsGeneratorConversions/GettingStarted":{"abstract":[{"type":"codeVoice","code":"GUUnitsGeneratorConversions"},{"type":"text","text":" is the main target of "},{"type":"codeVoice","code":"guunits_generator"},{"type":"text","text":". This target provides the unit and category"},{"type":"text","text":" "},{"type":"text","text":"definitions for all the code generated in "},{"type":"codeVoice","code":"GUUnits"},{"type":"text","text":"."}],"kind":"article","type":"topic","role":"article","title":"Getting Started","url":"\/documentation\/guunitsgeneratorconversions\/gettingstarted","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GettingStarted"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/CreatingCompositeUnits":{"abstract":[{"type":"text","text":"This guide demonstrates the process for creating "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite units"}]},{"type":"text","text":". A composite unit is a unit category"},{"type":"text","text":" "},{"type":"text","text":"that is created from other units."}],"kind":"article","type":"topic","role":"article","title":"Creating Composite Units","url":"\/documentation\/guunitsgeneratorconversions\/creatingcompositeunits","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CreatingCompositeUnits"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/AnyGenerator":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyGenerator"}],"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/AnyGenerator","navigatorTitle":[{"kind":"identifier","text":"AnyGenerator"}],"abstract":[{"text":"A type-erased UnitGenerator.","type":"text"}],"type":"topic","role":"symbol","title":"AnyGenerator","kind":"symbol","url":"\/documentation\/guunitsgeneratorconversion