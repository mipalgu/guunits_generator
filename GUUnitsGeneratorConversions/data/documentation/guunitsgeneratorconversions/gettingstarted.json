{"abstract":[{"code":"GUUnitsGeneratorConversions","type":"codeVoice"},{"type":"text","text":" is the main target of "},{"code":"guunits_generator","type":"codeVoice"},{"type":"text","text":". This target provides the unit and category"},{"type":"text","text":" "},{"type":"text","text":"definitions for all the code generated in "},{"type":"codeVoice","code":"GUUnits"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions"]]},"identifier":{"url":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"The target is broken up into 3 key subdirectories:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"units"}]}]},{"content":[{"inlineContent":[{"code":"source_generation","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"test_generation"}]}]}]},{"inlineContent":[{"type":"text","text":"We will examine each of these subdirectories in the following sections. For a quick guide explaining how to create a new unit,"},{"type":"text","text":" "},{"type":"text","text":"see the "},{"isActive":true,"identifier":"creatingnewunits","type":"reference"},{"text":" document.","type":"text"}],"type":"paragraph"},{"text":"Units","level":2,"anchor":"Units","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"units","type":"codeVoice"},{"text":" subdirectory is the simplist of all the other subdirectories. This folder contains the category definitions for each","type":"text"},{"text":" ","type":"text"},{"text":"unit type. A category is simply a group of units that describe\/measure the same phenomenon. For example, consider the ","type":"text"},{"code":"Distance","type":"codeVoice"},{"text":" ","type":"text"},{"text":"category which contains the units ","type":"text"},{"code":"metres","type":"codeVoice"},{"text":", ","type":"text"},{"code":"centimetres","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"millimetres","type":"codeVoice"},{"text":". This category is defined in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/DistanceUnits","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"All categories must conform to the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitProtocol","type":"reference"},{"text":" protocol to allow source and test generation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition to the units definitions, this subdirectory also contains the ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Swift","type":"codeVoice"},{"text":" primitive types that are supported","type":"text"},{"text":" ","type":"text"},{"text":"by ","type":"text"},{"code":"GUUnits","type":"codeVoice"},{"text":". You may view the supported C types in ","type":"text"},{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/NumericTypes","isActive":true,"type":"reference"},{"text":", and the supported ","type":"text"},{"code":"Swift","type":"codeVoice"},{"text":" types in ","type":"text"},{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/SwiftNumericTypes","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"All units can be converted to\/from these supported primitive types.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Lastly, it is worth mentioning that each unit type (e.g. "},{"type":"codeVoice","code":"metres"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"Distance"},{"type":"text","text":" category) has 4 different underlying types that support"},{"type":"text","text":" "},{"text":"varying levels of precision. These types are the ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" primitive types ","type":"text"},{"code":"double","type":"codeVoice"},{"text":", ","type":"text"},{"code":"float","type":"codeVoice"},{"text":", ","type":"text"},{"code":"uint64_t","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"int64_t","type":"codeVoice"},{"text":". Each unit is therefore","type":"text"},{"text":" ","type":"text"},{"text":"represented as a new type depending on it’s precision and is suffixed with ","type":"text"},{"code":"_d","type":"codeVoice"},{"text":", ","type":"text"},{"code":"_f","type":"codeVoice"},{"text":", ","type":"text"},{"code":"_u","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"_t","type":"codeVoice"},{"text":" for ","type":"text"},{"code":"double","type":"codeVoice"},{"text":", ","type":"text"},{"code":"float","type":"codeVoice"},{"text":", ","type":"text"},{"code":"unit64_t","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"int64_t","type":"codeVoice"},{"text":" respectively in the source code. For example, consider the ","type":"text"},{"code":"metres","type":"codeVoice"},{"text":" unit; in the generated ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" source code, the ","type":"text"},{"code":"metres","type":"codeVoice"},{"text":" ","type":"text"},{"text":"unit is represented as 4 ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" types: ","type":"text"},{"code":"metres_d","type":"codeVoice"},{"text":", ","type":"text"},{"code":"metres_f","type":"codeVoice"},{"text":", ","type":"text"},{"code":"metres_u","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"metres_t","type":"codeVoice"},{"text":". The different versions of the unit type is referred","type":"text"},{"text":" ","type":"text"},{"text":"to in this documentation as a units ","type":"text"},{"code":"Sign","type":"codeVoice"},{"text":", and is defined in the enum ","type":"text"},{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/Signs","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Source Generation","level":2,"anchor":"Source-Generation","type":"heading"},{"inlineContent":[{"text":"This subdirectory contains the code required to generate the ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Swift","type":"codeVoice"},{"text":" sources for all of the units and their conversions.","type":"text"},{"text":" ","type":"text"},{"text":"In order to generate the correct sources for each unit, an equivalent ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/FunctionBodyCreator","type":"reference"},{"text":" must be used for that unit type.","type":"text"},{"text":" ","type":"text"},{"text":"Simple types using ","type":"text"},{"code":"SI","type":"codeVoice"},{"text":" prefixes can utilise the existing ","type":"text"},{"code":"GradualFunctionCreator","type":"codeVoice"},{"text":" which performs simple multiplication or","type":"text"},{"text":" ","type":"text"},{"text":"division with a pre-defined scale factor (see ","type":"text"},{"isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Creating New Units"}],"identifier":"creatingnewunits","overridingTitle":"Creating New Units","type":"reference"},{"text":"). If any unit performs conversions that","type":"text"},{"text":" ","type":"text"},{"text":"cannot be defined as a simple multiplication or divide, then a custom ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/FunctionBodyCreator","type":"reference"},{"text":" must be defined that implements","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" code to perform the conversion.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To keep consistency between all unit categories, the definitions of the functions in "},{"code":"C","type":"codeVoice"},{"type":"text","text":" will follow a naming convention that"},{"type":"text","text":" "},{"type":"text","text":"is enforced by "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CFunctionDefinitionCreator","type":"reference"},{"type":"text","text":". When used in tandem with "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CompositeFunctionCreator","type":"reference"},{"type":"text","text":" and "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/NumericTypeConverter","type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"C","type":"codeVoice"},{"type":"text","text":" implementation is automatically created using the "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/FunctionBodyCreator","type":"reference"},{"type":"text","text":" of that unit. This process is completely"},{"type":"text","text":" "},{"type":"text","text":"automated and is not usually altered when adding new units. For convenience, all source generation is performed through"},{"type":"text","text":" "},{"type":"text","text":"a "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitsGenerator","type":"reference"},{"type":"text","text":" that combines these types. For brevity, a new unit typically creates an extension on "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitsGenerator","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and a "},{"code":"typealias","type":"codeVoice"},{"type":"text","text":" to allow easy initialisation (see "},{"isActive":true,"identifier":"creatingnewunits","overridingTitle":"Creating New Units","type":"reference","overridingTitleInlineContent":[{"text":"Creating New Units","type":"text"}]},{"type":"text","text":"). This process is demonstrated"},{"type":"text","text":" "},{"type":"text","text":"for the "},{"isActive":true,"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TemperatureUnits","type":"reference"},{"type":"text","text":" category below."}],"type":"paragraph"},{"code":["\/\/\/ TemperatureUnits initialiser for C conversions.","extension UnitsGenerator where","    Creator == CompositeFunctionCreator<","        TemperatureFunctionCreator,","        CFunctionDefinitionCreator<TemperatureUnits>,","        NumericTypeConverter","    > {","","    \/\/\/ Initialise using TemperatureUnits and C conversions.","    \/\/\/ - Parameters:","    \/\/\/   - bodyCreator: The creator which generates function bodies.","    \/\/\/   - definitionCreator: The definitionCreate which generates function definitions.","    \/\/\/   - numericConverter: The numericConverter which generates numeric type conversions.","    \/\/\/   - helpers: The helpers which generate function names and some definitions.","    public init(","        bodyCreator: TemperatureFunctionCreator = TemperatureFunctionCreator(),","        definitionCreator: CFunctionDefinitionCreator<TemperatureUnits> = CFunctionDefinitionCreator(),","        numericConverter: NumericTypeConverter = NumericTypeConverter(),","        helpers: FunctionHelpers<Creator.Unit> = FunctionHelpers<Creator.Unit>()","    ) {","        self.init(creator: CompositeFunctionCreator(","            bodyCreator: bodyCreator,","            definitionCreator: definitionCreator,","            numericConverter: numericConverter","        ))","    }","","}","","\/\/\/ Temperature Units Generator","public typealias TemperatureUnitsGenerator = UnitsGenerator<","    CompositeFunctionCreator<","        TemperatureFunctionCreator,","        CFunctionDefinitionCreator<TemperatureUnits>,","        NumericTypeConverter","    >",">"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The top level code may then create a source generator for ","type":"text"},{"type":"codeVoice","code":"Temperature"},{"text":" by invoking:","type":"text"}],"type":"paragraph"},{"code":["let generator = TemperatureUnitsGenerator()"],"syntax":"swift","type":"codeListing"},{"text":"Test Generation","level":2,"anchor":"Test-Generation","type":"heading"},{"inlineContent":[{"type":"text","text":"This package also generates tests for the "},{"type":"codeVoice","code":"C"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Swift"},{"type":"text","text":" sources. All of the code that handles the test generation"},{"type":"text","text":" "},{"type":"text","text":"is contained within the "},{"type":"codeVoice","code":"test_generation"},{"type":"text","text":" folder. A test in this package is represented as an input to output relationship."},{"type":"text","text":" "},{"type":"text","text":"Given some input, the test will perform a function with that input and assert that the output from the function matches the"},{"type":"text","text":" "},{"type":"text","text":"expected output. This relationship is defined inside a "},{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","type":"reference","isActive":true},{"type":"text","text":" that creates arrays of input to output relationships"},{"type":"text","text":" "},{"type":"text","text":"(using "},{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestParameters","type":"reference","isActive":true},{"type":"text","text":") for a given conversion function."}],"type":"paragraph"},{"inlineContent":[{"text":"Simple types using ","type":"text"},{"code":"SI","type":"codeVoice"},{"text":" prefixes may use the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GradualTestGenerator","isActive":true},{"text":" to generate the tests for them. Custom unit types or","type":"text"},{"text":" ","type":"text"},{"text":"those that cannot use the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GradualFunctionCreator","isActive":true},{"text":" to implement their conversion function must create a custom type","type":"text"},{"text":" ","type":"text"},{"text":"that conforms to ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","isActive":true},{"text":". The default implementation of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","isActive":true},{"text":" will provide the test cases","type":"text"},{"text":" ","type":"text"},{"text":"for the numeric conversions, i.e conversions containing the types defined in ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/NumericTypes","isActive":true},{"text":". The custom","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","isActive":true},{"text":" will only need to provide the tests for a unit to unit conversion.","type":"text"}],"type":"paragraph"},{"text":"Public Interface","level":2,"anchor":"Public-Interface","type":"heading"},{"inlineContent":[{"type":"text","text":"The entire public interface to this target is encapsulated within "},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GUUnitsGenerator","isActive":true},{"type":"text","text":". This struct provides methods"},{"type":"text","text":" "},{"type":"text","text":"for generating sources and tests for the "},{"code":"C","type":"codeVoice"},{"type":"text","text":" and "},{"code":"Swift","type":"codeVoice"},{"type":"text","text":" targets of the "},{"code":"GUUnits","type":"codeVoice"},{"type":"text","text":" package. The respective methods"},{"type":"text","text":" "},{"type":"text","text":"in this struct will use the "},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitsGenerator","isActive":true},{"type":"text","text":" for souce generation, the "},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitProtocol","isActive":true},{"type":"text","text":" for unit definition,"},{"type":"text","text":" "},{"type":"text","text":"and the "},{"type":"reference","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","isActive":true},{"type":"text","text":" for test generation following the procedures outlined above. An example of this entire process"},{"type":"text","text":" "},{"type":"text","text":"is shown in "},{"overridingTitleInlineContent":[{"type":"text","text":"Creating New Units"}],"type":"reference","overridingTitle":"Creating New Units","identifier":"creatingnewunits","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/guunitsgeneratorconversions\/gettingstarted"]}],"metadata":{"modules":[{"name":"GUUnitsGeneratorConversions"}],"title":"Getting Started","role":"article","roleHeading":"Article"},"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CreatingNewUnits","doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UsingCustomCodeGeneration","doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CreatingCompositeUnits","doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/ConvertingBetweenCategories"]}],"kind":"article","sections":[],"references":{"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/CreatingCompositeUnits":{"role":"article","title":"Creating Composite Units","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CreatingCompositeUnits","kind":"article","abstract":[{"text":"This guide demonstrates the process for creating ","type":"text"},{"inlineContent":[{"type":"text","text":"composite units"}],"type":"emphasis"},{"text":". A composite unit is a unit category","type":"text"},{"text":" ","type":"text"},{"text":"that is created from other units.","type":"text"}],"type":"topic","url":"\/documentation\/guunitsgeneratorconversions\/creatingcompositeunits"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/NumericTypeConverter":{"url":"\/documentation\/guunitsgeneratorconversions\/numerictypeconverter","abstract":[{"text":"A struct for converting between numeric types and unit types.","type":"text"}],"type":"topic","title":"NumericTypeConverter","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NumericTypeConverter","kind":"identifier"}],"navigatorTitle":[{"text":"NumericTypeConverter","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/NumericTypeConverter"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/CreatingNewUnits":{"role":"article","title":"Creating New Units","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CreatingNewUnits","kind":"article","abstract":[{"type":"text","text":"Provides a guide and example for creating new units."}],"type":"topic","url":"\/documentation\/guunitsgeneratorconversions\/creatingnewunits"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/DistanceUnits":{"url":"\/documentation\/guunitsgeneratorconversions\/distanceunits","abstract":[{"text":"A Unit for representing distances.","type":"text"}],"type":"topic","title":"DistanceUnits","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistanceUnits","kind":"identifier"}],"navigatorTitle":[{"text":"DistanceUnits","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/DistanceUnits"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions":{"url":"\/documentation\/guunitsgeneratorconversions","abstract":[{"text":"A target for generating the GUUnits package.","type":"text"}],"type":"topic","title":"GUUnitsGeneratorConversions","role":"collection","kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/TestParameters":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TestParameters","kind":"identifier"}],"title":"TestParameters","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestParameters","kind":"symbol","abstract":[{"text":"Class for storing expected test result from an input.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"TestParameters","kind":"identifier"}],"url":"\/documentation\/guunitsgeneratorconversions\/testparameters"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/GUUnitsGenerator":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GUUnitsGenerator","kind":"identifier"}],"title":"GUUnitsGenerator","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GUUnitsGenerator","kind":"symbol","abstract":[{"text":"Create the source files the C and swift targets of guunits.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"GUUnitsGenerator","kind":"identifier"}],"url":"\/documentation\/guunitsgeneratorconversions\/guunitsgenerator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/TestGenerator":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TestGenerator"}],"title":"TestGenerator","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/TestGenerator","kind":"symbol","abstract":[{"type":"text","text":"Conforming types will generate test parameters for a specific unit."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"TestGenerator"}],"url":"\/documentation\/guunitsgeneratorconversions\/testgenerator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/ConvertingBetweenCategories":{"role":"article","title":"Coverting Between Categories","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/ConvertingBetweenCategories","kind":"article","abstract":[{"type":"text","text":"This guide provides instructions for creating relations between different unit categories. A user may use a relation to convert a unit"},{"text":" ","type":"text"},{"text":"into another unit from a different category.","type":"text"}],"type":"topic","url":"\/documentation\/guunitsgeneratorconversions\/convertingbetweencategories"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/GradualTestGenerator":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GradualTestGenerator","kind":"identifier"}],"title":"GradualTestGenerator","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GradualTestGenerator","kind":"symbol","abstract":[{"text":"Struct used to generate test parameters for units that are convertable using","type":"text"},{"text":" ","type":"text"},{"text":"constant factors. e.g. 10 millimetres in a centimetre.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"GradualTestGenerator","kind":"identifier"}],"url":"\/documentation\/guunitsgeneratorconversions\/gradualtestgenerator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/SwiftNumericTypes":{"type":"topic","navigatorTitle":[{"text":"SwiftNumericTypes","kind":"identifier"}],"title":"SwiftNumericTypes","kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/SwiftNumericTypes","url":"\/documentation\/guunitsgeneratorconversions\/swiftnumerictypes","abstract":[{"type":"text","text":"A type containing Swift-supported types for guunits."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SwiftNumericTypes"}],"role":"symbol"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/CFunctionDefinitionCreator":{"url":"\/documentation\/guunitsgeneratorconversions\/cfunctiondefinitioncreator","abstract":[{"text":"Function that generates the C function definitions for converting between units and numeric types within","type":"text"},{"text":" ","type":"text"},{"text":"the same unit category.","type":"text"}],"type":"topic","title":"CFunctionDefinitionCreator","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CFunctionDefinitionCreator","kind":"identifier"}],"navigatorTitle":[{"text":"CFunctionDefinitionCreator","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CFunctionDefinitionCreator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/CompositeFunctionCreator":{"url":"\/documentation\/guunitsgeneratorconversions\/compositefunctioncreator","abstract":[{"text":"A function creator that delegates all methods to stored body creators, definition creators,","type":"text"},{"text":" ","type":"text"},{"text":"and numeric converters.","type":"text"}],"type":"topic","title":"CompositeFunctionCreator","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CompositeFunctionCreator","kind":"identifier"}],"navigatorTitle":[{"text":"CompositeFunctionCreator","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/CompositeFunctionCreator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/Signs":{"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Signs"}],"title":"Signs","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/Signs","kind":"symbol","abstract":[{"type":"text","text":"Enum containing the standard guunits signs."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Signs"}],"url":"\/documentation\/guunitsgeneratorconversions\/signs"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/NumericTypes":{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/NumericTypes","abstract":[{"text":"The numeric types supported by guunits.","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NumericTypes","kind":"identifier"}],"type":"topic","kind":"symbol","title":"NumericTypes","url":"\/documentation\/guunitsgeneratorconversions\/numerictypes","navigatorTitle":[{"text":"NumericTypes","kind":"identifier"}],"role":"symbol"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/UsingCustomCodeGeneration":{"role":"article","title":"Using Custom Code Generation","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UsingCustomCodeGeneration","kind":"article","abstract":[{"type":"text","text":"This document provides a guide for creating custom source and test generation for a unit category that requires"},{"text":" ","type":"text"},{"text":"custom conversion functions.","type":"text"}],"type":"topic","url":"\/documentation\/guunitsgeneratorconversions\/usingcustomcodegeneration"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/FunctionBodyCreator":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"FunctionBodyCreator"}],"title":"FunctionBodyCreator","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/FunctionBodyCreator","kind":"symbol","abstract":[{"type":"text","text":"Protocol that generates the code for the implementation of a conversion function."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FunctionBodyCreator"}],"url":"\/documentation\/guunitsgeneratorconversions\/functionbodycreator"},"creatingnewunits":{"identifier":"creatingnewunits","url":"creatingnewunits","type":"link","titleInlineContent":[{"type":"text","text":"Creating New Units"}],"title":"Creating New Units"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/GradualFunctionCreator":{"title":"GradualFunctionCreator","kind":"symbol","abstract":[{"text":"A function body creator that converts between different units by scaling","type":"text"},{"text":" ","type":"text"},{"text":"the magnitude of one unit by a constant value. Examples of this type of","type":"text"},{"text":" ","type":"text"},{"text":"behaviour is seen in SI units where kilo is 1000 times smaller than the","type":"text"},{"text":" ","type":"text"},{"text":"Mega prefix.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GradualFunctionCreator"}],"navigatorTitle":[{"kind":"identifier","text":"GradualFunctionCreator"}],"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/GradualFunctionCreator","url":"\/documentation\/guunitsgeneratorconversions\/gradualfunctioncreator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/UnitsGenerator":{"url":"\/documentation\/guunitsgeneratorconversions\/unitsgenerator","abstract":[{"text":"Struct that generates the code for all the possible conversion functions.","type":"text"}],"type":"topic","title":"UnitsGenerator","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnitsGenerator","kind":"identifier"}],"navigatorTitle":[{"text":"UnitsGenerator","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitsGenerator"},"doc://GUUnitsGeneratorConversions/documentation/GUUnitsGeneratorConversions/UnitProtocol":{"identifier":"doc:\/\/GUUnitsGeneratorConversions\/documentation\/GUUnitsGeneratorConversions\/UnitProtocol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"UnitProtocol"}],"url":"\/documentation\/guunitsgeneratorconversions\/unitprotocol","kind":"symbol","role":"symbol","title":"UnitProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnitProtocol"}],"abstract":[{"type":"text","text":"A protocol 